# --- Microsoft Entra ID (Azure AD) ---
# Directory (tenant) ID of your Entra tenant.
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
# Application (client) ID of the MCP server app registration.
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
# Client secret of the MCP server app registration. Keep this only in .env.
# Required UNLESS you use a managed identity (see below).
AZURE_CLIENT_SECRET=your-client-secret

# --- Managed identity (recommended when deployed to Azure) ---
# Set to true to authenticate to Entra with a managed identity federated
# credential instead of a client secret for the On-Behalf-Of exchange. When
# true, AZURE_CLIENT_SECRET is not needed.
AZURE_USE_MANAGED_IDENTITY=false
# Client ID of the user-assigned managed identity. Leave blank to use the
# system-assigned managed identity of the host (e.g. the Container App).
AZURE_MANAGED_IDENTITY_CLIENT_ID=

# --- MCP server (FastMCP) ---
# Public base URL of this server. Published in the Protected Resource Metadata
# so clients know this server's resource identifier.
MCP_BASE_URL=http://localhost:8000
# Interface / port the HTTP transport binds to.
MCP_HOST=127.0.0.1
MCP_PORT=8000
# Custom API scope name(s) exposed under "Expose an API" (comma separated).
MCP_REQUIRED_SCOPES=jobs

# --- Azure Databricks ---
# Workspace URL (no trailing slash).
DATABRICKS_HOST=https://adb-1234567890123456.7.azuredatabricks.net
# Jobs REST API version (2.2 is current; set 2.1 only if your workspace needs it).
DATABRICKS_API_VERSION=2.2
